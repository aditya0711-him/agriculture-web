# .gitattributes - Git attributes for consistent line endings\n\n# Auto detect text files and normalize line endings to LF\n* text=auto\n\n# Core files\n*.js text eol=lf\n*.jsx text eol=lf\n*.ts text eol=lf\n*.tsx text eol=lf\n*.py text eol=lf\n*.json text eol=lf\n*.md text eol=lf\n*.yml text eol=lf\n*.yaml text eol=lf\n\n# Binary files\n*.png binary\n*.jpg binary\n*.jpeg binary\n*.gif binary\n*.ico binary\n*.mov binary\n*.mp4 binary\n*.mp3 binary\n*.gz binary\n*.zip binary\n*.jar binary\n"